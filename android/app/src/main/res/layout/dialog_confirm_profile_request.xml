<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_confirm_dialog"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="22dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/tvConfirmDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Approve request"
        android:textColor="#111827"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvConfirmDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Approve profile changes for this driver?"
        android:textColor="#4B5563"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDialogCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="96dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#374151"
            android:textSize="14sp"
            app:backgroundTint="#ECECEC"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDialogAction"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:minWidth="100dp"
            android:text="Approve"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/dark_blue"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>