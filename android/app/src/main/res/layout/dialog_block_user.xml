<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView
        android:id="@+id/tvBlockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Block user?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0A0F2C"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etBlockReason"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Write reason... (optional)"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelBlock"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:backgroundTint="#E0E0E0"
            android:textColor="#333333"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/btnConfirmBlock"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Block"
            android:textAllCaps="false"
            android:backgroundTint="#0A0F2C"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>