<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EEEEEE"
        android:orientation="vertical">

        <include
            android:id="@+id/navbar"
            layout="@layout/view_navbar" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingEnd="16dp"
                android:paddingBottom="32dp">

                <!-- Tabs -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTabCustomers"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:text="Customers"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            app:backgroundTint="@color/dark_blue"
                            app:cornerRadius="8dp"
                            app:strokeColor="#D1D5DB"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTabDrivers"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="5dp"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:text="Drivers"
                            android:textAllCaps="false"
                            android:textColor="@color/dark_blue"
                            android:textSize="12sp"
                            app:backgroundTint="@android:color/white"
                            app:cornerRadius="8dp"
                            app:strokeColor="#D1D5DB"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabRequests"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:maxLines="1"
                        android:text="Profile Change Requests"
                        android:textAllCaps="false"
                        android:textColor="@color/dark_blue"
                        android:textSize="12sp"
                        app:backgroundTint="@android:color/white"
                        app:cornerRadius="8dp"
                        app:strokeColor="#D1D5DB"
                        app:strokeWidth="1dp" />

                </LinearLayout>

                <!-- Driver-only extras -->

                <LinearLayout
                    android:id="@+id/layoutDriverExtras"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvRegisterDriver"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_secondary_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Register new driver"
                        android:textColor="@color/dark_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/searchWrap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_ride_card"
                        android:padding="10dp">

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@android:color/transparent"
                            android:hint="Search drivers"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Section title -->

                <TextView
                    android:id="@+id/tvSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="12dp"
                    android:text="All customers"
                    android:textColor="#3E5547"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <!-- User list / request empty state -->

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvUsers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingBottom="24dp" />

                    <LinearLayout
                        android:id="@+id/requestsEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="360dp"
                        android:layout_marginStart="2dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_requests_empty_state"
                        android:elevation="3dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="28dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋"
                            android:textSize="54sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center"
                            android:text="No pending requests"
                            android:textColor="#111827"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="All profile change requests have been processed."
                            android:textColor="#6B7280"
                            android:textSize="14sp" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A0F2C"
        app:itemBackground="@android:color/transparent"
        app:itemTextColor="@android:color/white"
        app:menu="@menu/loged_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>