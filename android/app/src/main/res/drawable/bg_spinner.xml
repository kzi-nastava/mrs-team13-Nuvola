<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">

        <shape android:shape="rectangle">

            <solid android:color="#F8FAFC" />

            <corners android:radius="9dp" />

            <stroke
                android:width="2dp"
                android:color="#0A0F2C" />

            <padding
                android:left="12dp"
                android:top="4dp"
                android:right="12dp"
                android:bottom="4dp" />

        </shape>

    </item>

    <item>

        <shape android:shape="rectangle">

            <solid android:color="#FFFFFF" />

            <corners android:radius="9dp" />

            <stroke
                android:width="1dp"
                android:color="#9CA3AF" />

            <padding
                android:left="12dp"
                android:top="4dp"
                android:right="12dp"
                android:bottom="4dp" />

        </shape>

    </item>

</selector>